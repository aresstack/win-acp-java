# Auto-detect text files and normalise line endings
* text=auto

# Shell scripts must keep LF and be marked executable
gradlew        text eol=lf
*.sh           text eol=lf

# Batch files must keep CRLF
*.bat          text eol=crlf
*.cmd          text eol=crlf

# Gradle wrapper JAR is binary
gradle/wrapper/gradle-wrapper.jar binary

